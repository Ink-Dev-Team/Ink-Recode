{
    // 深色主题配色方案 - 基于种子色 #7632E6（紫色系）生成
    "darkTheme": {
        // 主色调 - 界面主要强调色
        "primary": { "hex": "#D2BCFD", "rgb": "rgb(210, 188, 253)" },          // 主色（浅紫）：用于按钮、选中状态等
        "surfaceTint": { "hex": "#D2BCFD", "rgb": "rgb(210, 188, 253)" },      // 表面着色：用于给表面元素添加主色调的淡色
        "onPrimary": { "hex": "#38265C", "rgb": "rgb(56, 38, 92)" },            // 主色上的文字色（深紫）：保证在primary上的可读性
        "primaryContainer": { "hex": "#4F3D74", "rgb": "rgb(79, 61, 116)" },   // 主色容器（深紫）：用于卡片、面板等容器背景
        "onPrimaryContainer": { "hex": "#EADDFF", "rgb": "rgb(234, 221, 255)" },// 主色容器上的文字色（浅紫）：保证在primaryContainer上的可读性

        // 次要色调 - 辅助主色调的配色
        "secondary": { "hex": "#CDC2DB", "rgb": "rgb(205, 194, 219)" },        // 次要色（浅紫灰）：用于次要按钮、次要强调
        "onSecondary": { "hex": "#342D40", "rgb": "rgb(52, 45, 64)" },          // 次要色上的文字色（深紫灰）
        "secondaryContainer": { "hex": "#4B4358", "rgb": "rgb(75, 67, 88)" },  // 次要色容器（深紫灰）
        "onSecondaryContainer": { "hex": "#E9DEF8", "rgb": "rgb(233, 222, 248)" },// 次要色容器上的文字色

        // 第三色调 - 用于强调特殊状态/元素
        "tertiary": { "hex": "#F0B7C5", "rgb": "rgb(240, 183, 197)" },          // 第三色（浅粉紫）：用于提醒、特殊标签等
        "onTertiary": { "hex": "#4A2530", "rgb": "rgb(74, 37, 48)" },            // 第三色上的文字色（深粉紫）
        "tertiaryContainer": { "hex": "#643B46", "rgb": "rgb(100, 59, 70)" },    // 第三色容器（深粉紫）
        "onTertiaryContainer": { "hex": "#FFD9E1", "rgb": "rgb(255, 217, 225)" },// 第三色容器上的文字色

        // 错误状态配色
        "error": { "hex": "#FFB4AB", "rgb": "rgb(255, 180, 171)" },             // 错误色（浅红）：用于错误提示、失败状态
        "onError": { "hex": "#690005", "rgb": "rgb(105, 0, 5)" },                // 错误色上的文字色（深红）
        "errorContainer": { "hex": "#93000A", "rgb": "rgb(147, 0, 10)" },       // 错误容器背景色（深红）
        "onErrorContainer": { "hex": "#FFDAD6", "rgb": "rgb(255, 218, 214)" },   // 错误容器上的文字色（浅红）

        // 基础背景/表面配色
        "background": { "hex": "#151218", "rgb": "rgb(21, 18, 24)" },           // 全局背景色（深黑紫）：App整体背景
        "onBackground": { "hex": "#E7E0E8", "rgb": "rgb(231, 224, 232)" },      // 背景上的文字色（浅灰紫）
        "surface": { "hex": "#151218", "rgb": "rgb(21, 18, 24)" },              // 表面色：卡片、组件等容器背景（同background）
        "onSurface": { "hex": "#E7E0E8", "rgb": "rgb(231, 224, 232)" },         // 表面上的文字色（同onBackground）
        "surfaceVariant": { "hex": "#49454E", "rgb": "rgb(73, 69, 78)" },       // 表面变体：次要容器背景（浅于surface）
        "onSurfaceVariant": { "hex": "#CBC4CF", "rgb": "rgb(203, 196, 207)" },  // 表面变体上的文字色

        // 边框/阴影配色
        "outline": { "hex": "#948F99", "rgb": "rgb(148, 143, 153)" },           // 轮廓线色：按钮、输入框边框
        "outlineVariant": { "hex": "#49454E", "rgb": "rgb(73, 69, 78)" },       // 轮廓线变体：次要边框
        "shadow": { "hex": "#000000", "rgb": "rgb(0, 0, 0)" },                  // 阴影色：组件阴影
        "scrim": { "hex": "#000000", "rgb": "rgb(0, 0, 0)" },                   // 遮罩色：弹窗遮罩

        // 反色配色 - 用于反转对比的场景
        "inverseSurface": { "hex": "#E7E0E8", "rgb": "rgb(231, 224, 232)" },    // 反色表面：反转后的背景
        "inverseOnSurface": { "hex": "#322F35", "rgb": "rgb(50, 47, 53)" },      // 反色表面上的文字色
        "inversePrimary": { "hex": "#67548E", "rgb": "rgb(103, 84, 142)" },      // 反色主色：反转后的主色

        // 固定配色 - 不受主题切换影响的固定色值
        "primaryFixed": { "hex": "#EADDFF", "rgb": "rgb(234, 221, 255)" },      // 固定主色
        "onPrimaryFixed": { "hex": "#230F46", "rgb": "rgb(35, 15, 70)" },        // 固定主色上的文字色
        "primaryFixedDim": { "hex": "#D2BCFD", "rgb": "rgb(210, 188, 253)" },    // 固定主色（暗版）
        "onPrimaryFixedVariant": { "hex": "#4F3D74", "rgb": "rgb(79, 61, 116)" },// 固定主色变体上的文字色

        // 表面容器系列 - 不同深浅的表面色，用于区分层级
        "surfaceDim": { "hex": "#151218", "rgb": "rgb(21, 18, 24)" },           // 暗表面：最低层级背景
        "surfaceBright": { "hex": "#3B383E", "rgb": "rgb(59, 56, 62)" },        // 亮表面：高亮容器背景
        "surfaceContainerLowest": { "hex": "#0F0D13", "rgb": "rgb(15, 13, 19)" },// 表面容器（最低）：最暗的容器背景
        "surfaceContainerLow": { "hex": "#1D1B20", "rgb": "rgb(29, 27, 32)" },   // 表面容器（低）：较暗的容器背景
        "surfaceContainer": { "hex": "#211F24", "rgb": "rgb(33, 31, 36)" },      // 表面容器（默认）：标准容器背景
        "surfaceContainerHigh": { "hex": "#2B292F", "rgb": "rgb(43, 41, 47)" },  // 表面容器（高）：较亮的容器背景
        "surfaceContainerHighest": { "hex": "#36343A", "rgb": "rgb(54, 52, 58)" }// 表面容器（最高）：最亮的容器背景
    }
}